rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Invitation list — public read (to check status), no client writes
    match /invitations/{email} {
      allow read: if true;
      allow write: if false;
    }

    // User profile — owner only
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Usage / rate limit counters — written by server (Admin SDK) only
    match /usage/{docId} {
      allow read, write: if false;
    }
  }
}
