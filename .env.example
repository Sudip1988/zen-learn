# ── Firebase (client-side — safe to expose) ───────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── App metadata ──────────────────────────────────────────────────────────────
VITE_APP_VERSION=2.1.0

# ── Server-side secrets (Vercel env vars ONLY — never put in .env file) ───────
# Add these in: Vercel Dashboard → Project → Settings → Environment Variables

# Your Anthropic API key
ANTHROPIC_API_KEY=

# Your YouTube Data API v3 key
YOUTUBE_API_KEY=

# Firebase service account — full JSON on one line
# Generate: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Max catalogue discoveries per user per day (default: 5)
DAILY_DISCOVERY_LIMIT=5
